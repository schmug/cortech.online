---
import Base from '../layouts/Base.astro';
import { FEEDS } from './feeds.opml';
---

<Base
  title="Feeds"
  description="Every RSS feed published by cortech.online, plus a one-click OPML subscription list."
  canonical="https://cortech.online/feeds"
>
  <section class="mx-auto max-w-2xl px-6 pt-16 pb-10">
    <div>
      <p class="font-mono text-[11px] tracking-[0.35em] text-[var(--color-amber)] uppercase">
        Feeds
      </p>
      <h1 class="mt-2 text-3xl font-[var(--font-display)] font-bold tracking-tight sm:text-4xl">
        Subscribe to cortech.online
      </h1>
      <p class="mt-3 max-w-xl text-sm text-[var(--color-muted)]">
        Everything here is also an RSS feed. <a
          href="/rss.xml"
          class="text-[var(--color-amber)] hover:underline">Cortech — everything</a
        > is the firehose; the rest are topic feeds. Grab them all at once with the
        <a href="/feeds.opml" class="text-[var(--color-amber)] hover:underline">OPML file</a> — most readers
        can import it in one click.
      </p>
    </div>

    <ul class="mt-10 divide-y divide-[var(--color-border)]">
      {
        FEEDS.map((feed) => (
          <li class="py-5">
            <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <a
                href={feed.pagePath}
                class="text-lg font-[var(--font-display)] font-semibold tracking-tight hover:text-[var(--color-amber)]"
              >
                {feed.title}
              </a>
              <a
                href={feed.feedPath}
                class="font-mono text-xs text-[var(--color-amber)] hover:underline"
              >
                {feed.feedPath}
              </a>
            </div>
            <p class="mt-1 text-sm text-[var(--color-muted)]">{feed.description}</p>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
